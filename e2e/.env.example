# Local config for `bun run test:e2e` (CI supplies these as job env instead).
# Copy to e2e/.env and fill in. See ADR-0048.

# --- Database (the ephemeral/e2e Neon branch — NOT prod) ---
# Migrations must already be applied to this branch.
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# --- Clerk (real dev instance — the e2e API runs the real AuthGuard) ---
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."

# The dedicated Clerk dev-instance test user the suite signs in as, and whose
# stable Clerk user id (`sub`) all seeded data is scoped to.
E2E_TEST_USER_ID="user_..."
E2E_CLERK_USER_EMAIL="e2e-test-user@example.com"
E2E_CLERK_USER_PASSWORD="..."

# --- Optional: run the same specs against a deployed URL (#436) ---
# When set, the local API + web servers are NOT booted; specs run against this
# base URL instead.
# E2E_BASE_URL="https://preprod.gigloop..."
