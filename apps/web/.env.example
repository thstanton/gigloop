VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Base URL prefixed to every API request. Unset defaults to the relative
# /api path, which relies on the deployment's rewrite config (e.g.
# apps/web/vercel.json) to reach the correct API. Set this explicitly for
# environments — like the preprod smoke-test build — that must not fall
# through to the prod rewrite.
VITE_API_BASE_URL=

# Example feature flag (see src/lib/featureFlags.ts for the convention).
# Default-off: unset, empty, "false", or "0" all resolve to off; "true" or
# "1" turns it on. Vite only exposes VITE_-prefixed vars to client code, so
# flag names must use that prefix.
VITE_FEATURE_EXAMPLE=
