VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Base URL prefixed to every API request. Unset defaults to the relative
# /api path, which relies on the deployment's rewrite config (e.g.
# apps/web/vercel.json) to reach the correct API. Set this explicitly for
# environments — like the preprod smoke-test build — that must not fall
# through to the prod rewrite.
VITE_API_BASE_URL=
