# Neon connection strings. Find these in the Neon console: your project →
# Connection Details (toggle "Pooled connection" for the -pooler host).
#
#   DATABASE_URL — POOLED (-pooler host, pgbouncer=true). Used at runtime by
#                  PrismaService for queries.
#   DIRECT_URL   — DIRECT (no -pooler, no pgbouncer). Used by the Prisma CLI /
#                  schema `directUrl` for migrations (migrate deploy needs a
#                  session-level connection that pgbouncer's transaction pooling
#                  breaks).
#
# connect_timeout=15 & pool_timeout=15: Neon scales the compute to zero when
# idle; a cold resume (~5–10s) exceeds Prisma's 5s default and times out (#612).
# The raised timeout lets each connect attempt wait out the resume.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connect_timeout=15&pool_timeout=15"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Clerk secret key — find in Clerk dashboard → API Keys
CLERK_SECRET_KEY="sk_test_..."

# Cloudflare R2 — find in R2 dashboard → Manage R2 API tokens
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
# Public assets bucket (musician logos/photos) — public access ENABLED.
# The `-public` suffix is a safety signal: anything here is world-readable,
# so NEVER store sensitive data (contracts, invoices, PII) in it. Those go in
# the private R2_DOCUMENTS_BUCKET_NAME bucket below (ADR-0059).
R2_BUCKET_NAME="gigloop-public"
# Public URL for the assets bucket (custom domain or the r2.dev subdomain).
# Must match R2_BUCKET_NAME — logoUrl/photo are stored as full URLs, so this
# host is baked into saved rows and sent-email <img> tags.
R2_PUBLIC_URL="https://pub-xxx.r2.dev"
# Private bucket for Documents (contracts, invoices, uploads, song lists) —
# public access DISABLED. Served only via access-controlled, presigned GETs
# (ADR-0059). No public URL: objects are never world-readable. Uses the same
# R2_ACCOUNT_ID / access keys above (the API token must be scoped to this
# bucket too). Assets (logos/photos) stay in R2_BUCKET_NAME.
R2_DOCUMENTS_BUCKET_NAME="gigloop-documents"

# AES-256-GCM key for encrypting bankDetails at rest.
# Must be exactly 64 hex characters (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="<64-hex-chars>"

# Resend — find API key in Resend dashboard → API Keys
# For development use onboarding@resend.dev (only delivers to your Resend account email)
# For production use a verified domain address e.g. "GigMan <noreply@gigman.com>"
RESEND_API_KEY="re_..."
RESEND_FROM="onboarding@resend.dev"

# Base URL of the frontend app — used to construct portal links in emails
# e.g. http://localhost:5173 for development, https://app.gigman.com for production
APP_BASE_URL="http://localhost:5173"

# Allowed CORS origin for the API — set to the frontend URL in production
# e.g. https://app.gigman.com; falls back to http://localhost:5173 in development
CORS_ORIGIN="https://app.gigman.com"

# Google Maps Distance Matrix API key — required for travel time calculation
# Obtain at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable "Distance Matrix API" for the key
GOOGLE_MAPS_API_KEY="AIza..."

# Example feature flag (see src/common/featureFlags.ts for the convention).
# Default-off: unset, empty, "false", or "0" all resolve to off; "true" or
# "1" turns it on.
FEATURE_EXAMPLE=

# Synthetic user id for `bun run seed` (prisma/seed.ts). Must equal a real
# Clerk-dev user id in the environment the seed is run against, or the
# AuthGuard scopes queries to the signed-in user and the seeded data is
# invisible after sign-in (ADR-0044 §7). Defaults to Tim's own Clerk dev
# user id for local seeding when unset.
SEED_USER_ID=
