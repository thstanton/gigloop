# Neon connection string.
# Find this in the Neon console: your project → Connection Details → Connection string.
#
# Used in three places — all pointing at the same value:
#   1. schema.prisma  datasource url    (required by Prisma's schema validator)
#   2. prisma.config.ts datasource.url  (used by the Prisma CLI for migrations)
#   3. PrismaService at runtime         (used by the Neon adapter for queries)
#
# A single URL covers all three. No DIRECT_URL needed.
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Clerk secret key — find in Clerk dashboard → API Keys
CLERK_SECRET_KEY="sk_test_..."

# Cloudflare R2 — find in R2 dashboard → Manage R2 API tokens
R2_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="gigman"
# Public URL for the bucket (custom domain or the r2.dev subdomain)
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# AES-256-GCM key for encrypting bankDetails at rest.
# Must be exactly 64 hex characters (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="<64-hex-chars>"
