generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum BookingStatus {
  ENQUIRY
  PROVISIONAL
  CONFIRMED
  READY
  COMPLETE
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

enum DocumentType {
  CONTRACT
  INVOICE
  SONG_LIST
}

enum CommunicationStatus {
  PENDING
  SENT
  FAILED
}

// ─────────────────────────────────────────
// Models
// ─────────────────────────────────────────

model PublicProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessName        String  @default("")
  displayName         String?
  bio                 String?
  email               String?
  phone               String?
  logoUrl             String?
  photo               String?
  website             String?
  socials             Json?
  clientPortalConfig  Json    @default("{}")

  @@index([userId])
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  address                 String?
  bankDetails             String?
  vatNumber               String?
  vatRate                 Int     @default(20)
  defaultPaymentTermsDays Int     @default(14)
  invoiceNumberSequence   Int     @default(0)
  invoiceSequenceYear     Int     @default(0)
  depositPercentage       Int?

  digestEmailEnabled         Boolean @default(true)
  songRequestFormEnabled     Boolean @default(true)

  preferences Json @default("{}")
}

model Contact {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  greetingName String?
  email        String?
  phone        String?
  address String?
  notes   String?
  primaryRole String?

  // Venue-specific fields
  parkingInfo        String?
  accessInfo         String?
  equipmentAvailable String?

  // Booking agent-specific fields
  website               String?
  commissionArrangement String?

  customerBookings     Booking[]       @relation("BookingCustomer")
  venueBookings        Booking[]       @relation("BookingVenue")
  bookingAgentBookings Booking[]       @relation("BookingAgent")
  invoices         Invoice[]
  communications   Communication[]

  @@index([userId])
}

model Booking {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status      BookingStatus @default(ENQUIRY)
  eventType   String
  date        DateTime
  title       String?
  fee         Decimal?      @db.Decimal(10, 2)
  notes               String?
  portalToken         String    @unique @default(uuid())
  depositReceivedAt     DateTime?

  customerId String
  customer   Contact @relation("BookingCustomer", fields: [customerId], references: [id], onDelete: Restrict)

  venueId String?
  venue   Contact? @relation("BookingVenue", fields: [venueId], references: [id], onDelete: Restrict)

  bookingAgentId String?
  bookingAgent   Contact? @relation("BookingAgent", fields: [bookingAgentId], references: [id], onDelete: Restrict)

  sets              PerformanceSet[]
  performanceFormats BookingPerformanceFormat[]
  invoices          Invoice[]
  communications    Communication[]
  documents         Document[]
  musicFormConfig   MusicFormConfig?
  musicFormResponse MusicFormResponse?
  contracts         Contract[]
  checklistItems    BookingChecklistItem[]

  @@index([userId])
  @@index([customerId])
  @@index([venueId])
  @@index([bookingAgentId])
}

model BookingChecklistItem {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  key              String?
  label            String
  completedBy      String    @default("USER")
  state            String    @default("PENDING")
  order            Int
  dependsOn        String[]
  autoCompleteRule Json?
  requiredForStatus String?
  completedAt      DateTime?
  dueDate          DateTime?
  dueDateRule      Json?

  @@index([userId])
  @@index([bookingId])
}

model Contract {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookingId        String
  booking          Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  status           String     @default("DRAFT")
  content          Json
  signedAt         DateTime?
  signedFromIp     String?
  signatureDataUrl String?
  voidedAt         DateTime?

  documents        Document[]

  @@index([userId])
  @@index([bookingId])
}

model PerformanceSet {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Int
  duration  Int
  startTime String?
  label     String?

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  performanceFormatId String?
  performanceFormat   PerformanceFormat? @relation(fields: [performanceFormatId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bookingId])
  @@index([performanceFormatId])
}

model PerformanceFormat {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  label                 String
  category              String?
  icon                  String
  keyMoments            String[]
  defaultGenreSelection String[]
  notes                 String?

  slots          PerformanceFormatSlot[]
  bookingFormats BookingPerformanceFormat[]
  sets           PerformanceSet[]

  @@index([userId])
}

model PerformanceFormatSlot {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  label    String?
  duration Int
  order    Int

  performanceFormatId String
  performanceFormat   PerformanceFormat @relation(fields: [performanceFormatId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([performanceFormatId])
}

model BookingPerformanceFormat {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Int

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  performanceFormatId String
  performanceFormat   PerformanceFormat @relation(fields: [performanceFormatId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([bookingId])
  @@index([performanceFormatId])
}

model Invoice {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status        InvoiceStatus @default(DRAFT)
  isDeposit     Boolean       @default(false)
  invoiceNumber String?
  issueDate     DateTime?
  dueDate       DateTime?
  paidAt        DateTime?

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  billToContactId String
  billToContact   Contact @relation(fields: [billToContactId], references: [id], onDelete: Restrict)

  lineItems InvoiceLineItem[]
  documents Document[]

  @@index([userId])
  @@index([bookingId])
}

model InvoiceLineItem {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  description String
  amount      Decimal @db.Decimal(10, 2)
  order       Int     @default(0)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([invoiceId])
}

model Template {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  content     Json
  builtInType String?

  communications Communication[]

  @@index([userId])
}

model Communication {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  direction String              @default("OUTBOUND")
  channel   String              @default("EMAIL")
  status    CommunicationStatus @default(SENT)
  subject   String
  body      String
  sentAt    DateTime?

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Restrict)

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bookingId])
}

model Document {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type       DocumentType
  storageKey String

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // null for non-INVOICE documents; set for INVOICE documents
  invoiceId String?
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  // null for non-CONTRACT documents; set when a signed contract PDF is generated
  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bookingId])
  @@index([contractId])
}

model Song {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title  String
  artist String?
  genre  String
  active Boolean   @default(true)
  tags   String[]

  @@index([userId])
}

model MusicFormConfig {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enabledGenres String[]
  keyMoments    Json     @default("[]")

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MusicFormResponse {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  selectedSongIds String[]
  specialRequests Json
  notes           String?
  submittedAt     DateTime @default(now())

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([userId])
}
