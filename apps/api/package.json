{
  "name": "@gigloop/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint src --max-warnings 0",
    "test": "jest",
    "test:integration": "jest --config jest.integration.json --runInBand",
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "seed:checklists": "ts-node -r tsconfig-paths/register src/scripts/seed-checklists.ts"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1051.0",
    "@aws-sdk/s3-request-presigner": "^3.1051.0",
    "@clerk/backend": "^3.4.11",
    "@neondatabase/serverless": "^0.9.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-neon": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "pdfmake": "^0.3.9",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.12.3",
    "rxjs": "^7.8.1",
    "ws": "^8.17.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.3.1",
    "@types/pdfmake": "^0.3.3",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "eslint": "^10.4.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.10",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.60.0"
  }
}
